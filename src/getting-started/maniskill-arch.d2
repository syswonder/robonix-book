direction: down

user: 用户 { shape: person }
tui: rbnx chat (TUI)

pilot: robonix-pilot {
  style.fill: "#E8F0FE"
  style.stroke: "#4285F4"
}
vlm: vlm_service (gRPC) {
  style.fill: "#E8F0FE"
  style.stroke: "#4285F4"
}
atlas: robonix-atlas {
  style.fill: "#FCE4EC"
  style.stroke: "#E91E63"
}

env: env_node · ManiSkill3 (gRPC) {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
}
perception: perception_node · GroundingDINO (MCP) {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
}
policy: policy_node · Octo/Scripted (MCP) {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
}
viz: viz_node · Rerun (gRPC) {
  style.fill: "#F3E5F5"
  style.stroke: "#9C27B0"
}

user -> tui: 指令
tui -> pilot: HandleIntent
pilot -> vlm: CognitionService.Reason

pilot -> perception: MCP
pilot -> policy: MCP
policy -> env: gRPC
perception -> env: gRPC
viz -> env: gRPC
viz -> perception: MCP

